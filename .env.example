# The atproto handle whose repo holds the dreams (reads are public, no secret needed)
ATPROTO_HANDLE=paolo.ricciuti.me

# Optional: skip handle resolution by pinning the DID and/or PDS URL
# ATPROTO_DID=did:plc:ezyrzvz3yoglekd4j2szmiys
# ATPROTO_SERVICE=https://npmx.social

# App password created on the PDS — lets the /admin dashboard write dreams
# ATPROTO_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Password that guards the /admin dashboard
# ADMIN_PASSWORD=choose-something-long

# Coolify API — lets the admin dashboard trigger a redeploy when the diary
# changes, so the prerendered pages get rebuilt with fresh data
# COOLIFY_URL=https://ricciuti.app
# COOLIFY_TOKEN=xxxx
# COOLIFY_TAG=dreams
